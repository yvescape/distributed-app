# ── Stage 1 : Builder ────────────────────────────────────────────────
FROM python:3.12-alpine AS builder
WORKDIR /app

# psycopg2-binary est une wheel pré-compilée → plus besoin de gcc/musl/postgresql-dev
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip \
    && pip install -r requirements.txt

# ── Stage 2 : Runtime ────────────────────────────────────────────────
FROM python:3.12-alpine
WORKDIR /app

# libpq reste nécessaire à l'exécution (psycopg2-binary l'embarque déjà,
# mais apk upgrade peut en avoir besoin selon la version alpine)
# Met apk upgrade EN PREMIER pour maximiser le cache de couche
RUN apk add --no-cache libpq \
    && apk upgrade --no-cache

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN adduser -D -u 1001 django

COPY --chown=django:django entrypoint.sh .
COPY --chown=django:django interation/ ./interation/

RUN sed -i 's/\r$//' ./entrypoint.sh && chmod +x ./entrypoint.sh

RUN DJANGO_SETTINGS_MODULE=interation.settings.base \
    SECRET_KEY=build-only-dummy-key \
    ALLOWED_HOSTS=localhost \
    DB_ENGINE=django.db.backends.postgresql \
    DB_NAME=dummy \
    DB_USER=dummy \
    DB_PASSWORD=dummy \
    DB_HOST=localhost \
    DB_PORT=5432 \
    python interation/manage.py collectstatic --noinput

USER django

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DJANGO_SETTINGS_MODULE=interation.settings.base

LABEL org.opencontainers.image.title="interation-service"
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health/')" || exit 1

ENTRYPOINT ["./entrypoint.sh"]